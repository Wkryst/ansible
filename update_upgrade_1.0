---
- name: Full unattended update → upgrade → reboot
  hosts: all
  become: yes

  tasks:
    - name: Wait until apt/dpkg processes finish (unattended upgrades etc.)
      shell: |
        set -o pipefail
        if pgrep -x apt apt-get dpkg unattended-upgrade >/dev/null 2>&1; then
          exit 1
        fi
        exit 0
      args:
        executable: /bin/bash
      register: apt_procs
      until: apt_procs.rc == 0
      retries: 60
      delay: 5
      changed_when: false

    - name: Wait until apt/dpkg locks are NOT held (advisory check)
      shell: |
        set -o pipefail
        locks=(
          /var/lib/dpkg/lock
          /var/lib/dpkg/lock-frontend
          /var/lib/apt/lists/lock
          /var/cache/apt/archives/lock
        )
        for f in "${locks[@]}"; do
          if [ -e "$f" ] && command -v fuser >/dev/null 2>&1; then
            if fuser "$f" >/dev/null 2>&1; then
              exit 1
            fi
          fi
        done
        exit 0
      args:
        executable: /bin/bash
      register: lock_check
      until: lock_check.rc == 0
      retries: 60
      delay: 5
      changed_when: false

    - name: Update apt cache (valid for 1h)
      apt:
        update_cache: yes
        cache_valid_time: 3600
        lock_timeout: 300
      tags: update

    - name: Upgrade all packages non-interactively
      apt:
        upgrade: dist
        autoremove: yes
        autoclean: yes
        dpkg_options:
          - force-confdef
          - force-confold
        lock_timeout: 300
      environment:
        DEBIAN_FRONTEND: noninteractive
      register: upgrade_result
      tags: upgrade

    - name: Check if reboot is required
      stat:
        path: /var/run/reboot-required
      register: reboot_required
      tags: reboot_check

    - name: Reboot if required (detached)
      reboot:
        reboot_timeout: 600
        test_command: whoami
        post_reboot_delay: 30
      when: reboot_required.stat.exists
      async: 1
      poll: 0
      tags: reboot